NODE_ENV=development
# 3001 avoids clashing with other tools that bind 3000; override if you prefer 3000.
PORT=3001

# MySQL (TCP). For Cloud SQL on Cloud Run, use the instance connection name with Cloud SQL Auth Proxy
# or set DB_SOCKET_PATH to /cloudsql/PROJECT:REGION:INSTANCE for Unix socket.
DB_HOST=127.0.0.1
# Use 3308 with the repo root `docker-compose.yml` (host port → container 3306).
DB_PORT=3308
DB_NAME=docking_admin
DB_USER=root
DB_PASSWORD=secret

# Optional: Unix socket path (GCP Cloud Run + Cloud SQL). When set, host/port are ignored by mysql2.
# DB_SOCKET_PATH=/cloudsql/my-project:us-central1:my-instance

# Serverless-friendly pool (keep max small per instance)
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Comma-separated origins for CORS (Vue dev server + production URL)
CORS_ORIGINS=http://localhost:5173

# Default admin created by npm run db:seed-admin (only if no admins exist)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme
